# ─── OpenClaw Gateway ──────────────────────────────
# Auth is handled by trusted-proxy mode (Caddy injects X-Forwarded-User).
# Token-based auth is disabled — leave commented out.
# OPENCLAW_GATEWAY_TOKEN=
# Password fallback for local CLI access (generated by `make init`).
OPENCLAW_GATEWAY_PASSWORD=
# Host's static LAN IP (Caddy binds to this interface). Required for LAN access.
OPENCLAW_LAN_IP=

# ─── AI Provider API Keys ─────────────────────────
# LM Studio uses a dummy key — no API key needed.
# Uncomment and fill in other providers if used.
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# GOOGLE_GENERATIVE_AI_API_KEY=
