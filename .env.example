# Application
DEBUG=true

# Local model — set to enable (llama-cpp is Docker Model Runner default)
LOCAL_MODEL=llama-cpp
LOCAL_MODEL_ID=huggingface.co/bartowski/google_gemma-3-1b-it-gguf:latest

# ── Networking ────────────────────────────────────────────────────────────────
#
# STATIC_IP — The host machine's IP address on your trusted network interface.
#   Caddy binds ports 80 and 443 to this specific IP only, so the listening
#   socket is never reachable from other network interfaces (e.g. a guest or
#   IoT network on the same machine).
#   Example: 10.20.30.4
#
# TRUSTED_SUBNET — The CIDR of the network that is allowed to reach this
#   service. Caddy enforces this at the application layer: any connection whose
#   source IP is not within this range (or DOCKER_SUBNET) receives a 403 and
#   the connection is closed immediately.
#
#   Best practice: use a dedicated subnet that contains only devices you own
#   and trust (e.g. a separate VLAN, a management network, a VPN tunnel
#   address pool). Avoid using a broad subnet that also covers guest devices,
#   IoT hardware, or shared infrastructure.
#
#   This should match the subnet that STATIC_IP lives on.
#   Example: 10.20.30.0/24
#
# DOCKER_SUBNET — The bridge subnet Docker assigns to the openclaw-net
#   network (defined in docker-compose.yml under networks.openclaw-net.ipam).
#   Must be included in Caddy's IP filter so containers can reach the gateway.
#   Change both this value and the docker-compose.yml subnet together.
#   Example: 172.30.0.0/16
#
STATIC_IP=10.20.30.4
TRUSTED_SUBNET=10.20.30.0/24
DOCKER_SUBNET=172.30.0.0/16
GATEWAY_PORT=18789
LOCAL_MODEL_PORT=12434

# Secrets
OPENCLAW_GATEWAY_PASSWORD=REPLACE_ME
DUCKDNS_DOMAIN=
DUCKDNS_TOKEN=
DEEPSEEK_API_KEY=
