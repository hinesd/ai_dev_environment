# ─── Secrets ───────────────────────────────
OPENCLAW_GATEWAY_PASSWORD=

# ─── DuckDNS ────────────────────────────────
DUCKDNS_DOMAIN=
DUCKDNS_TOKEN=

# ─── Mode ───────────────────────────────────
# true  = local inference (starts Ollama container, pulls qwen2.5:7b)
# false = cloud inference (uses DeepSeek API — set DEEPSEEK_API_KEY below)
DEBUG=true

# ─── Default model ──────────────────────────
# Set automatically by DEBUG above via make. If running docker compose
# directly (without make), uncomment one of these:
# OPENCLAW_DEFAULT_MODEL=ollama/qwen2.5:7b
# OPENCLAW_DEFAULT_MODEL=deepseek/deepseek-chat

# ─── DeepSeek ───────────────────────────────
# API key from https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=
