{
  gateway: {
    mode: "local",
    bind: "loopback",
    controlUi: {
      allowedOrigins: ["http://localhost:${OPENCLAW_GATEWAY_PORT}", "http://127.0.0.1:${OPENCLAW_GATEWAY_PORT}", "https://${DUCKDNS_DOMAIN}"],
      allowInsecureAuth: false,
    },
    auth: {
      mode: "password",
      password: { source: "env", provider: "default", id: "OPENCLAW_GATEWAY_PASSWORD" },
      rateLimit: { maxAttempts: 50, windowMs: 60000, lockoutMs: 5000 },
    },
    trustedProxies: ["${OPENCLAW_DOCKER_SUBNET}"],
    nodes: {
      pairing: {
        autoApproveCidrs: ["${OPENCLAW_DOCKER_SUBNET}"],
      },
    },
  },
  session: {
    dmScope: "per-channel-peer",
  },
  agents: {
    defaults: {
      model: { primary: "ollama/qwen2.5:7b" },
      workspace: "/home/node/.openclaw/workspace",
    },
  },
  models: {
    providers: {
      ollama: {
        baseUrl: "http://ollama:11434/v1",
        api: "openai-completions",
        timeoutSeconds: 600,
        models: [
          {
            id: "qwen2.5:7b",
            name: "Qwen 2.5 7B (Ollama)",
            reasoning: true,
            input: ["text"],
            contextWindow: 131072,
            maxTokens: 8192,
          },
        ],
      },
    },
  },
  tools: {
    byProvider: {
      "ollama/qwen2.5:7b": { deny: ["group:web", "browser"] },
    },
    web: {
      search: { enabled: false },
      fetch: { enabled: false },
    },
  },
  browser: { enabled: false },
}
